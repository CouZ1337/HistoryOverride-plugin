{
  "manifest_version": 2,
  "name": "HistoryOverride",
  "version": "1.0",
  "description": "Браузерное расширение, позволяющее не записывать историю с выбранных сайтов.",
  "icons": {
    "48": "hello_extensions.png"
  },
  "permissions": [
    "history",
    "webNavigation",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": "hello_extensions.png",
    "default_title": "History Override",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "HistoryOverride-plugin@from.github.com",
	  "data_collection_permissions": {"required": ["none"]},
      "strict_min_version": "142.0"
    }
  }
}
